# =============================================================================
# VT-SaiBER Environment Variables
# =============================================================================
# IMPORTANT: This is an example file, never commit .env to git!
# This file contains example values for environment variables used by VT-SaiBER.
# Copy this file to .env and fill in the actual values before running the application.

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# -----------------------------------------------------------------------------
# Shared LLM Configuration (all agents)
# -----------------------------------------------------------------------------
LLM_CLIENT=openrouter
LLM_MODEL=example-model

# -----------------------------------------------------------------------------
# Safety Controls
# -----------------------------------------------------------------------------
STRIKER_REQUIRE_CONFIRMATION=true

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_PASSWORD=choose_a_strong_password_here
DB_HOST=some_host_here
DB_PORT=some_port_here
DB_NAME=some_name_here
DB_USER=some_name_here

# -----------------------------------------------------------------------------
# RAG Retrieval Tuning
# -----------------------------------------------------------------------------
RAG_KB_TOP_K=8
RAG_KB_FETCH_K=24
RAG_FINDINGS_TOP_K=5
RAG_FINDINGS_FETCH_K=15
RAG_KB_SIMILARITY_THRESHOLD=0.58
RAG_FINDINGS_SIMILARITY_THRESHOLD=0.45
RAG_MIN_DOCS=3
RAG_MIN_SCORE=0.75
RAG_MAX_CHUNKS_PER_DOC=2

# -----------------------------------------------------------------------------
# Reporting
# -----------------------------------------------------------------------------
REPORT_EXPORT_DIR=

# -----------------------------------------------------------------------------
# Metasploit RPC Configuration
# -----------------------------------------------------------------------------
MSF_PASSWORD=another_strong_password_here
MSF_SERVER=some_server_here
MSF_PORT=some_port_here
MSF_SSL=true_or_false_here

# -----------------------------------------------------------------------------
# Kali Configuration
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# MCP Server URLs (internal Docker network)
# -----------------------------------------------------------------------------
KALI_MCP_URL=http://kali-mcp:5001
MSF_MCP_URL=http://msf-mcp:8085

# -----------------------------------------------------------------------------
# Tavily API Configuration
# -----------------------------------------------------------------------------
TAVILY_API_KEY=sk-tavily-your-tavily-key-here
TAVILY_MAX_RESULTS=5